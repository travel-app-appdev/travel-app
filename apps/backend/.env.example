# Server
PORT=3000

# Your Firebase Project ID (Firebase Console → Project settings)
FIREBASE_PROJECT_ID=

# Destination search — free key at https://www.geoapify.com/
GEOAPIFY_API_KEY=

# Optional on a server: paste the full service account JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: folder for trip photo uploads (must be writable)
# MEMORIES_UPLOAD_DIR=
